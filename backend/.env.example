# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# Model Configuration
MODEL_NAME=Think2Seg-RS-7B
MODEL_PATH=OpenGVLab/Think2Seg-RS-7B
DEVICE=cuda
DTYPE=bfloat16

# SAM2 Configuration
SAM2_MODEL_SIZE=base_plus
SAM2_DEVICE=cuda

# Inference Settings
MAX_IMAGE_SIZE=1024
INFERENCE_TIMEOUT=300
BATCH_SIZE=1

# Model Caching
USE_CACHE=true
CACHE_DIR=.model_cache

# VLLM Configuration
USE_VLLM=false
VLLM_TENSOR_PARALLEL_SIZE=1
