# API Configuration
API_HOST=0.0.0.0
API_PORT=8123
DEBUG=false
FRONTEND_PORT=3123
VITE_PORT=5173
# Optional override. If unset, CORS is derived from FRONTEND_PORT and VITE_PORT.
# CORS_ORIGINS=["http://localhost:3123", "http://localhost:5173"]

# Model Configuration
MODEL_NAME=Think2Seg-RS-7B
MODEL_PATH=RicardoString/Think2Seg-RS-7B
HF_TOKEN=
DEVICE=cuda
MODEL_DEVICE_MAP=auto
DTYPE=bfloat16
NVIDIA_VISIBLE_DEVICES=all
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# SAM2 Configuration
SAM2_MODEL_SIZE=base_plus
SAM2_DEVICE=cuda
SAM2_ROOT=/opt/sam2
# Optional explicit overrides if your SAM2 checkpoint/config live elsewhere.
# SAM2_CHECKPOINT=/opt/sam2/checkpoints/sam2.1_hiera_base_plus.pt
# SAM2_CONFIG=configs/sam2.1/sam2.1_hiera_b+.yaml

# Inference Settings
MAX_IMAGE_SIZE=1024
INFERENCE_TIMEOUT=300
BATCH_SIZE=1
MAX_NEW_TOKENS=1024
CLEAR_CUDA_CACHE_AFTER_RUN=true
ENABLE_TF32=true
AETHER_MIN_COMPONENT_AREA=50
AETHER_DEDUP_IOU_THRESHOLD=0.55
AETHER_DEDUP_CONTAINMENT_THRESHOLD=0.85
AETHER_CLASSIFICATION_SMOOTHING=0.01

# Ultra-Sim callback. Match ULTRA_SIM_CALLBACK_TOKEN to AETHER_HANDOFF_TOKEN.
ULTRA_SIM_CALLBACK_BASE_URL=
ULTRA_SIM_CALLBACK_TOKEN=
ULTRA_SIM_CALLBACK_TIMEOUT=60

# Model Caching
USE_CACHE=true
CACHE_DIR=.model_cache

# VLLM Configuration
USE_VLLM=false
VLLM_TENSOR_PARALLEL_SIZE=1
